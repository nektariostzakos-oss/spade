# Optional. Without it the app falls back to the original photo.
REMOVE_BG_API_KEY=your_remove_bg_key_here

# Optional. Powers the "Suggest copy" and "Suggest template" AI buttons.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional. Powers the "Generate background" AI image feature.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
