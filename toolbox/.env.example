# --- Core ---
NODE_ENV=development                         # development | production | test
LOG_LEVEL=debug                              # pino log level

# --- Database (local docker-compose defaults) ---
# Used by Prisma. For Neon in prod, swap to the pooled connection string.
DATABASE_URL=postgresql://toolbox:toolbox@localhost:5432/toolbox?schema=public

# --- Cache / queue ---
REDIS_URL=redis://localhost:6379

# --- Search ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=dev_master_key_change_me

# --- URLs the apps expect ---
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3100
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3100,http://localhost:8081

# --- Clerk (auth). Create project at dashboard.clerk.com ---
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Mux (video + live) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# --- OpenAI (embeddings + text moderation) ---
OPENAI_API_KEY=

# --- Stripe Connect (Express accounts for pros) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Mapbox ---
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Pusher (realtime) ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Object storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Video moderation (Hive.ai) ---
HIVE_API_KEY=

# --- Analytics (PostHog) ---
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=

# --- Error monitoring (Sentry) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
